{
  "manifest_version": 3,
  "name": "Immoscout24 Flat Comparison",
  "version": "1.0.1",
  "description": "Compare rental flats on ImmoScout24.de side-by-side. Save listings and view price, size, rooms, and location, etc in one table.",

  "permissions": ["storage"],

  "host_permissions": ["https://www.immobilienscout24.de/*"],

  "content_scripts": [
    {
      "matches": ["https://www.immobilienscout24.de/expose/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Immoscout24 Flat Comparison"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
